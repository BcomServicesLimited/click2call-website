Options -Indexes
DirectoryIndex index.html index.htm

# Force HTTPS + www
RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://www.%1%{REQUEST_URI} [R=301,L]

# Legacy URL redirects
Redirect 301 /pricing https://www.click2call.com.au/pricing.html
Redirect 301 /pricing/ https://www.click2call.com.au/pricing.html
Redirect 301 /tour https://www.click2call.com.au/about.html
Redirect 301 /contact https://www.click2call.com.au/contact.html
Redirect 301 /support https://www.click2call.com.au/support.html
